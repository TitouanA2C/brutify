# Copier en .env.local et renseigner les valeurs. Ne jamais commiter .env.local.

# Supabase (obligatoire)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (obligatoire pour paiements)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREATOR_MONTHLY_PRICE_ID=
STRIPE_CREATOR_YEARLY_PRICE_ID=
STRIPE_GROWTH_MONTHLY_PRICE_ID=
STRIPE_GROWTH_YEARLY_PRICE_ID=
STRIPE_SCALE_MONTHLY_PRICE_ID=
STRIPE_SCALE_YEARLY_PRICE_ID=
STRIPE_CREDITS_100_PRICE_ID=
STRIPE_CREDITS_300_PRICE_ID=
STRIPE_CREDITS_500_PRICE_ID=
STRIPE_CREDITS_1000_PRICE_ID=

# IA
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Scraping (Apify)
APIFY_API_KEY=

# Cron (secret pour /api/cron/*)
CRON_SECRET=

# App — URL publique du site (obligatoire en prod pour OAuth)
# En prod, définir l’URL exacte (ex: https://app.brutify.com).
# Dans Supabase : Authentication → URL Configuration → Site URL = cette URL ;
# Redirect URLs doit contenir https://votredomaine.com/callback
NEXT_PUBLIC_APP_URL=
